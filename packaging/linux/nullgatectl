#!/usr/bin/env bash
# Nullgate (Nullgate) â€” install / update / uninstall manager (Linux).
#
#   nullgatectl --install [--no-auto-update] [--no-gui-autostart]
#   nullgatectl --update  [--check]
#   nullgatectl --uninstall [--purge]
#   nullgatectl --status
#   nullgatectl --help
#
# Unlike a pure user app, Nullgate's daemon needs CAP_NET_ADMIN/CAP_NET_RAW to bring up
# the virtual interface (TUN). So the daemon is installed as a ROOT systemd system
# service (it gets the caps for free), with a root daily update timer â€” mirroring
# the Windows LocalSystem service + SYSTEM scheduled task. The GUI runs as your
# normal user and talks to the daemon over /tmp/nullgate.sock. Install/update/uninstall
# need root; this re-execs itself with sudo when not already root.
# Note: NO `pipefail`. Extraction pipelines use early-closing consumers
# (grep -m1 / head -n1) that make curl/find exit with EPIPE (e.g. curl's code 23);
# under pipefail that aborts the script even though the value was read fine. We
# guard results with `[ -n â€¦ ]` and use `|| die` on the standalone critical ops.
set -eu

REPO="${NULLGATE_BINARIES_REPO:-steeb-k/iroh-private-network}"
ASSET_RE='https://[^"]+linux-x86_64\.tar\.gz'

BIN_DIR="/usr/local/bin"
# Desktop entry + icons go under /usr/share, NOT /usr/local/share: /usr/share is
# always in XDG_DATA_DIRS, and /usr/share/icons/hicolor already has the theme's
# index.theme so gtk-update-icon-cache works and the launcher icon resolves.
# (/usr/local/share/icons/hicolor is a fresh dir with no index.theme and isn't
# always searched, which left the .desktop icon broken.)
APPS_DIR="/usr/share/applications"
ICONS_DIR="/usr/share/icons/hicolor"
METAINFO_DIR="/usr/share/metainfo"
UNIT_DIR="/etc/systemd/system"
AUTOSTART_DIR="/etc/xdg/autostart"
APP_ID="io.github.steeb_k.Nullgate"

WORKDIR=""
trap 'rm -rf "${WORKDIR:-}"' EXIT

log()  { printf '%s\n' "nullgatectl: $*"; }
die()  { printf '%s\n' "nullgatectl: error: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

# Re-exec with sudo for the privileged subcommands.
need_root() {
  if [ "$(id -u)" -ne 0 ]; then
    have sudo || die "must run as root (sudo not found)"
    exec sudo -- "$0" "$@"
  fi
}

version_gt() { [ "$1" != "$2" ] && [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -n1)" = "$2" ]; }
installed_version() { have nullgate-daemon && nullgate-daemon --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1; }

latest_version() {
  have curl || die "curl is required"
  curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null \
    | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name": *"v?([^"]+)".*/\1/'
}

# Download + extract the latest release; echo the extracted tree root.
fetch_latest_tree() {
  have curl || die "curl is required"
  local json url root
  json="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest")" || die "cannot reach $REPO releases API"
  url="$(printf '%s' "$json" | grep -oE "\"browser_download_url\": *\"$ASSET_RE\"" | sed -E 's/.*"(https[^"]+)".*/\1/' | head -n1)"
  [ -n "$url" ] || die "latest release has no linux-x86_64.tar.gz asset"
  WORKDIR="$(mktemp -d)"
  curl -fsSL -o "$WORKDIR/pkg.tgz" "$url" || die "download failed"
  tar -xzf "$WORKDIR/pkg.tgz" -C "$WORKDIR" || die "extract failed"
  root="$(find "$WORKDIR" -maxdepth 2 -type d -name bin -exec dirname {} \; | head -n1)"
  [ -n "$root" ] || die "archive missing a bin/ directory"
  printf '%s\n' "$root"
}

# Place files from a release tree ($1) system-wide. Atomic per file, so replacing
# the running daemon (or this very script) is safe. Shared by --install/--update.
apply_tree() {
  local src="$1"
  [ -x "$src/bin/nullgate-daemon" ] || die "release tree '$src' is incomplete"

  local was=0
  if systemctl is-active --quiet nullgate-daemon.service 2>/dev/null; then
    was=1; log "stopping nullgate-daemon"; systemctl stop nullgate-daemon.service || true
  fi

  install -d -m 0755 "$BIN_DIR"
  local f name
  for f in "$src"/bin/*; do
    name="$(basename "$f")"
    install -m 0755 "$f" "$BIN_DIR/$name.t$$"; mv -f "$BIN_DIR/$name.t$$" "$BIN_DIR/$name"
  done
  # The manager itself ships at the tree root; install it too.
  if [ -f "$src/nullgatectl" ]; then
    install -m 0755 "$src/nullgatectl" "$BIN_DIR/nullgatectl.t$$"; mv -f "$BIN_DIR/nullgatectl.t$$" "$BIN_DIR/nullgatectl"
  fi

  if [ -f "$src/share/applications/$APP_ID.desktop" ]; then
    install -d -m 0755 "$APPS_DIR"
    install -m 0644 "$src/share/applications/$APP_ID.desktop" "$APPS_DIR/$APP_ID.desktop"
  fi
  if [ -d "$src/share/icons/hicolor" ]; then
    install -d -m 0755 "$ICONS_DIR"; cp -r "$src"/share/icons/hicolor/* "$ICONS_DIR/"
  fi
  if [ -f "$src/share/metainfo/$APP_ID.metainfo.xml" ]; then
    install -d -m 0755 "$METAINFO_DIR"; install -m 0644 "$src/share/metainfo/$APP_ID.metainfo.xml" "$METAINFO_DIR/"
  fi

  local changed=0 u b
  if [ -d "$src/lib/systemd/system" ]; then
    install -d -m 0755 "$UNIT_DIR"
    for u in "$src"/lib/systemd/system/*; do
      b="$(basename "$u")"
      cmp -s "$u" "$UNIT_DIR/$b" || { install -m 0644 "$u" "$UNIT_DIR/$b"; changed=1; }
    done
  fi
  [ "$changed" = 1 ] && systemctl daemon-reload || true

  have gtk-update-icon-cache && gtk-update-icon-cache -qtf "$ICONS_DIR" 2>/dev/null || true
  have update-desktop-database && update-desktop-database -q "$APPS_DIR" 2>/dev/null || true

  [ "$was" = 1 ] && { log "starting nullgate-daemon"; systemctl start nullgate-daemon.service; } || true
}

cmd_install() {
  need_root "--install" "$@"
  local auto=1 gui=1 a
  for a in "$@"; do case "$a" in
    --no-auto-update) auto=0 ;;
    --no-gui-autostart) gui=0 ;;
    *) die "unknown flag for --install: $a" ;;
  esac; done

  # Prefer the tarball tree we were run from; otherwise download the latest.
  local here tree
  here="$(cd "$(dirname "$0")" && pwd)"
  if [ -x "$here/bin/nullgate-daemon" ]; then tree="$here"; else log "no local release tree; fetching latest"; tree="$(fetch_latest_tree)"; fi

  if have ldd; then
    local miss; miss="$(ldd "$tree/bin/nullgate" 2>/dev/null | awk '/not found/{print $1}' | sort -u || true)"
    [ -n "$miss" ] && { echo "nullgatectl: WARNING - missing shared libraries:" >&2; printf '  %s\n' $miss >&2; echo "  Install GTK 4.10+ and libadwaita 1.4+ (libgtk-4-1 libadwaita-1-0), then re-run." >&2; }
  fi

  log "installing"
  apply_tree "$tree"

  systemctl daemon-reload || true
  if [ "$gui" = 1 ] && [ -f "$APPS_DIR/$APP_ID.desktop" ]; then
    install -d -m 0755 "$AUTOSTART_DIR"
    sed "s|^Exec=.*|Exec=nullgate --minimized|" "$APPS_DIR/$APP_ID.desktop" > "$AUTOSTART_DIR/$APP_ID.desktop"
    echo "X-GNOME-Autostart-enabled=true" >> "$AUTOSTART_DIR/$APP_ID.desktop"
    log "tray GUI will start at login"
  fi
  systemctl enable --now nullgate-daemon.service && log "daemon enabled (starts at boot)" \
    || log "WARNING: could not enable the daemon; start it with: systemctl start nullgate-daemon"
  [ "$auto" = 1 ] && { systemctl enable --now nullgate-update.timer && log "daily auto-update enabled" || true; }

  log "done. Launch \"Nullgate\" from your app menu, or run: nullgate"
}

cmd_update() {
  local check=0 a
  for a in "$@"; do case "$a" in --check) check=1 ;; *) die "unknown flag for --update: $a" ;; esac; done

  local inst latest
  inst="$(installed_version || true)"
  [ -n "$inst" ] || die "not installed; run: nullgatectl --install"
  latest="$(latest_version)"
  [ -n "$latest" ] || die "could not determine the latest release"
  log "installed $inst, latest $latest"
  if ! version_gt "$inst" "$latest"; then log "up to date"; return 0; fi
  log "update available: $inst -> $latest"
  [ "$check" = 1 ] && return 0
  need_root "--update"
  local tree; tree="$(fetch_latest_tree)"
  apply_tree "$tree"
  log "updated to $latest"
}

cmd_uninstall() {
  need_root "--uninstall" "$@"
  local purge=0 a
  for a in "$@"; do case "$a" in --purge) purge=1 ;; *) die "unknown flag for --uninstall: $a" ;; esac; done

  systemctl disable --now nullgate-update.timer 2>/dev/null || true
  systemctl disable --now nullgate-daemon.service 2>/dev/null || true
  rm -f "$UNIT_DIR/nullgate-daemon.service" "$UNIT_DIR/nullgate-update.service" "$UNIT_DIR/nullgate-update.timer"
  systemctl daemon-reload || true
  rm -f "$BIN_DIR/nullgate-daemon" "$BIN_DIR/nullgate" "$BIN_DIR/nullgate-cli" "$BIN_DIR/nullgatectl"
  rm -f "$APPS_DIR/$APP_ID.desktop" "$AUTOSTART_DIR/$APP_ID.desktop" "$METAINFO_DIR/$APP_ID.metainfo.xml"
  find "$ICONS_DIR" -type f -name "$APP_ID.png" -delete 2>/dev/null || true
  have gtk-update-icon-cache && gtk-update-icon-cache -qtf "$ICONS_DIR" 2>/dev/null || true
  have update-desktop-database && update-desktop-database -q "$APPS_DIR" 2>/dev/null || true
  log "removed binaries, units, launcher, icons."
  if [ "$purge" = 1 ]; then
    rm -rf "/var/lib/nullgate" "$HOME/.local/share/io.github.steeb_k.nullgate"
    log "purged data dirs (any secrets in the OS keyring are left intact)."
  fi
}

cmd_status() {
  printf '%-10s %s\n' "installed:" "$(installed_version || echo none)"
  printf '%-10s %s\n' "latest:"    "$(latest_version 2>/dev/null || echo '?')"
  printf '%-10s %s / %s\n' "daemon:" "$(systemctl is-active nullgate-daemon.service 2>/dev/null || echo inactive)" "$(systemctl is-enabled nullgate-daemon.service 2>/dev/null || echo disabled)"
  printf '%-10s %s\n' "timer:"     "$(systemctl is-enabled nullgate-update.timer 2>/dev/null || echo disabled)"
}

usage() {
  cat <<'EOF'
Nullgate installer/updater

  nullgatectl --install [--no-auto-update] [--no-gui-autostart]
  nullgatectl --update  [--check]
  nullgatectl --uninstall [--purge]
  nullgatectl --status

The daemon installs as a root systemd service (needs CAP_NET_ADMIN for the TUN);
the GUI runs as your normal user. Install/update/uninstall use sudo.
EOF
}

case "${1:-}" in
  --install)   shift; cmd_install "$@" ;;
  --update)    shift; cmd_update "$@" ;;
  --uninstall) shift; cmd_uninstall "$@" ;;
  --status)    shift; cmd_status ;;
  --check)     cmd_update --check ;;
  -h|--help|"") usage ;;
  *)           die "unknown command: $1 (try --help)" ;;
esac
