# Keep shell scripts LF so they run under bash/WSL even when checked out on Windows.
*.sh text eol=lf
# Extensionless POSIX scripts + systemd units + plists must stay LF too.
packaging/linux/nullgatectl text eol=lf
packaging/macos/nullgatectl text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.plist text eol=lf
*.desktop text eol=lf
# PowerShell + Rust: normalize to LF in the repo; Git renders natively on checkout.
*.ps1 text
*.rs text
# Binary assets — never EOL-normalize.
*.png binary
*.xcf binary
*.ico binary
